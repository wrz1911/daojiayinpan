{
  "name": "qimen-yinpan",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "build:win": "npx electron-builder --win --x64",
    "build:linux": "npx electron-builder --linux"
  },
  "build": {
    "appId": "com.qimen.yinpan",
    "productName": "阴盘奇门遁甲",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "qimen_app/**/*",
      "css/**/*",
      "js/**/*",
      "icon.png"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "icon.png"
    }
  },
  "dependencies": {
    "@capacitor/android": "^7.2.1",
    "@capacitor/cli": "^7.2.1",
    "@capacitor/core": "^7.2.1",
    "jsdom": "^29.1.1"
  },
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3"
  }
}
